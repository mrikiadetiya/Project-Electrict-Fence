<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_bg"
    tools:context=".VoltageActivity">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/text_secondary" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_toEndOf="@id/btn_back"
            android:layout_centerVertical="true"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monitoring Output Pagar"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OutputStatus · Alarm · Pulse · Arus"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="20dp">

            <!-- Output Status Card (utama) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Status Output Pagar"
                        android:textColor="@color/neon_blue"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Output Status Value (besar) -->
                    <TextView
                        android:id="@+id/tv_output_status_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="-"
                        android:textColor="@color/text_secondary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="14dp" />

                    <!-- ProtectionStatus Row -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Status Proteksi" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_protection_status_val"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="-"
                            android:textColor="@color/neon_blue" android:textStyle="bold" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ContactDetected Alert Card (merah, GONE by default) -->
            <LinearLayout
                android:id="@+id/layout_contact_alert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#FF3D1C1C"
                android:orientation="horizontal"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠ "
                    android:textColor="@color/neon_red"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_contact_alert_msg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gangguan/kontak terdeteksi pada pagar."
                    android:textColor="@color/neon_red"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- EmergencyStop Alert Card (merah, GONE by default) -->
            <LinearLayout
                android:id="@+id/layout_emergency_alert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#FF3D1C1C"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚨 EMERGENCY STOP AKTIF"
                    android:textColor="@color/neon_red"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Sistem dimatikan total karena gangguan berulang lebih dari 3 kali. Tekan Reset Emergency untuk mengaktifkan kembali."
                    android:textColor="#FFFF8A80"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reset_emergency_voltage"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:text="RESET EMERGENCY"
                    android:textColor="@color/neon_red"
                    android:textStyle="bold"
                    app:backgroundTint="#FF1A0000"
                    app:cornerRadius="10dp"
                    app:icon="@android:drawable/ic_dialog_alert"
                    app:iconTint="@color/neon_red"
                    app:strokeColor="@color/neon_red"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <!-- Pulse Output Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="〜 Monitoring Pulse Output Pagar"
                        android:textColor="@color/neon_blue"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Pulse Warning Banner -->
                    <LinearLayout
                        android:id="@+id/layout_pulse_warning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="#FFFEECE8"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠ "
                            android:textColor="@color/neon_red"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tv_pulse_warning_msg"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/neon_red"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Pulse Stats Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="PULSE COUNT" android:textColor="@color/text_secondary"
                                android:textSize="10sp" android:textStyle="bold" />
                            <TextView android:id="@+id/tv_pulse_count"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/status_green"
                                android:textSize="36sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="total pulsa" android:textColor="@color/text_secondary"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="@color/glass_white" android:layout_marginHorizontal="16dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="JEDA PULSE" android:textColor="@color/text_secondary"
                                android:textSize="10sp" android:textStyle="bold" />
                            <TextView android:id="@+id/tv_pulse_interval"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0.00 detik"
                                android:textColor="@color/status_green"
                                android:textSize="22sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="antar pulsa" android:textColor="@color/text_secondary"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="14dp" />

                    <!-- Pulse Status -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Status Pulse" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_pulse_status_val"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Belum ada data"
                            android:textColor="@color/text_secondary" android:textStyle="bold" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="10dp" />

                    <!-- PulseLost -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pulse Lost" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_pulse_lost_val"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="-"
                            android:textColor="@color/text_secondary" android:textStyle="bold" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="10dp" />

                    <!-- RetryCount -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Retry Count" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_retry_count"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0"
                            android:textColor="@color/neon_blue" android:textStyle="bold" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Arus Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Arus Input Energizer"
                        android:textColor="@color/neon_blue"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Arus Value -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ARUS INPUT"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom">
                            <TextView
                                android:id="@+id/tv_current_val"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.000 A"
                                android:textColor="@color/neon_blue"
                                android:textSize="36sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="14dp" />

                    <!-- Status Arus Row -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Status Arus" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_current_status_val"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Belum ada data"
                            android:textColor="@color/text_secondary" android:textStyle="bold" />
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Alarm Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:id="@+id/layout_alarm_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔 Alarm Internal Energizer"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Status Alarm" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_alarm_val"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="✓ Normal"
                            android:textColor="@color/status_green" android:textStyle="bold" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tv_alarm_detail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Alarm internal energizer aktif. Kemungkinan terjadi gangguan pada pagar, ground, atau output energizer."
                        android:textColor="@color/neon_red"
                        android:textSize="12sp"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ContactDetected Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛡 Proteksi Kontak Pagar"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Kontak Terdeteksi" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_contact_detected_val"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="✓ Tidak ada"
                            android:textColor="@color/status_green" android:textStyle="bold" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="10dp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Retry Count" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_retry_count_contact"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0"
                            android:textColor="@color/neon_blue" android:textStyle="bold" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="10dp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Status Proteksi" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_protection_status_contact"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="-"
                            android:textColor="@color/neon_blue" android:textStyle="bold" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="10dp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Emergency Stop" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_emergency_stop_val"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="✓ Normal"
                            android:textColor="@color/status_green" android:textStyle="bold" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@color/card_bg"
        android:elevation="10dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:id="@+id/nav_home"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_today" app:tint="@color/text_secondary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Dashboard" android:textColor="@color/text_secondary" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_voltage"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_sort_by_size" app:tint="@color/neon_blue" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Monitoring" android:textColor="@color/neon_blue" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_gps"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_map" app:tint="@color/text_secondary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Lokasi" android:textColor="@color/text_secondary" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_notifications"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_popup_reminder" app:tint="@color/text_secondary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Notifikasi" android:textColor="@color/text_secondary" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_settings"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_preferences" app:tint="@color/text_secondary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Sistem" android:textColor="@color/text_secondary" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
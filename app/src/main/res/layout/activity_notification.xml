<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_bg"
    tools:context=".NotificationActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/black_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/text_primary" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notifikasi &amp; Alert"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status Notifikasi Realtime"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/logo_container"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="16dp"
            app:cardBackgroundColor="@color/black_bg"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="6dp"
                android:src="@drawable/app_logo" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <!-- Current Notification Card (GONE by default) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_current_notif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_dialog_alert"
                            app:tint="@color/neon_yellow"
                            android:layout_marginEnd="12dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOTIFIKASI AKTIF"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_current_notif_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="-"
                        android:textColor="@color/neon_red"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="14dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pesan Terakhir"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_current_notif_msg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="-"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- No Notification State -->
            <LinearLayout
                android:id="@+id/layout_no_notif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="48dp"
                android:visibility="visible">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Belum ada notifikasi"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Notifikasi dari ESP32 akan muncul di sini saat ada event alarm, kontak, atau pencurian"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <!-- Info Card tentang Notification Types -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ Tipe Notifikasi"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <!-- CONTACT_DETECTED -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CONTACT_DETECTED" android:textColor="@color/neon_red"
                            android:textStyle="bold" android:textSize="12sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Kontak pagar terdeteksi"
                            android:textColor="@color/text_secondary" android:textSize="12sp" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="8dp" />

                    <!-- EMERGENCY_STOP -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="EMERGENCY_STOP" android:textColor="@color/neon_red"
                            android:textStyle="bold" android:textSize="12sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Sistem darurat diaktifkan"
                            android:textColor="@color/text_secondary" android:textSize="12sp" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="8dp" />

                    <!-- AUTO_RESTART -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="AUTO_RESTART" android:textColor="@color/neon_yellow"
                            android:textStyle="bold" android:textSize="12sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Sistem restart otomatis"
                            android:textColor="@color/text_secondary" android:textSize="12sp" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="8dp" />

                    <!-- THEFT_DETECTED -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="THEFT_DETECTED" android:textColor="@color/neon_red"
                            android:textStyle="bold" android:textSize="12sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Perangkat berpindah lokasi"
                            android:textColor="@color/text_secondary" android:textSize="12sp" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>    <!-- Floating Bottom Navigation -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <LinearLayout android:id="@+id/nav_home"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_today" app:tint="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Dashboard" android:textColor="@color/text_secondary" android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_voltage"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_sort_by_size" app:tint="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Monitoring" android:textColor="@color/text_secondary" android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_gps"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_dialog_map" app:tint="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Lokasi" android:textColor="@color/text_secondary" android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btn_notifications"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_popup_reminder" app:tint="@color/neon_blue" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Notifikasi" android:textColor="@color/neon_blue" android:textSize="10sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_settings"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_preferences" app:tint="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Sistem" android:textColor="@color/text_secondary" android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
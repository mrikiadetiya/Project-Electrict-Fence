<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_bg"
    tools:context=".GPSActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header_gps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        app:layout_top_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GPS TRACKING"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_gps_status"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/presence_online"
            app:tint="@color/status_green" />
    </LinearLayout>

    <!-- Map Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_map"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/dark_grey"
        app:cardCornerRadius="20dp"
        app:layout_constraintBottom_toTopOf="@+id/card_coords"
        app:layout_constraintTop_toBottomOf="@id/header_gps">

        <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.cardview.widget.CardView>

    <!-- Coordinates Info -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_coords"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/dark_grey"
        app:cardCornerRadius="16dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_open_gmaps">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LATITUDE" android:textColor="@color/glass_white" android:textSize="10sp"/>
                    <TextView android:id="@+id/tv_lat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-7.123456" android:textColor="@color/neon_blue" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LONGITUDE" android:textColor="@color/glass_white" android:textSize="10sp"/>
                    <TextView android:id="@+id/tv_lng" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="112.654321" android:textColor="@color/neon_blue" android:textSize="18sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_last_update"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Last update: 2 mins ago"
                android:textColor="@color/glass_white"
                android:textSize="12sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Open in Gmaps Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_open_gmaps"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:text="OPEN IN GOOGLE MAPS"
        android:textColor="@color/black_bg"
        app:backgroundTint="@color/neon_blue"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
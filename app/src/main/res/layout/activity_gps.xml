<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_bg"
    tools:context=".GPSActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/black_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/text_primary" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lokasi &amp; Anti Pencurian"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPS · Home · TheftDetect"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/logo_container"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="16dp"
            app:cardBackgroundColor="@color/black_bg"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="6dp"
                android:src="@drawable/app_logo" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="20dp">

            <!-- Coordinates Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Koordinat GPS Perangkat"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <!-- Lat / Lng -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardBackgroundColor="@color/black_bg"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="LATITUDE" android:textColor="@color/text_secondary" android:textSize="10sp" />
                                <TextView android:id="@+id/tv_lat"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="-"
                                    android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardBackgroundColor="@color/black_bg"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="LONGITUDE" android:textColor="@color/text_secondary" android:textSize="10sp" />
                                <TextView android:id="@+id/tv_lng"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="-"
                                    android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <!-- Satellite info -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Satelit Terhubung" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_satellite"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="- satelit"
                            android:textColor="@color/neon_blue" android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_copy_coords"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            android:text="Salin"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            app:cornerRadius="12dp"
                            app:icon="@android:drawable/ic_menu_edit"
                            app:iconSize="14dp"
                            app:iconTint="@color/text_secondary"
                            app:strokeColor="@color/text_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_open_gmaps"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="2"
                            android:layout_marginStart="5dp"
                            android:text="Buka Google Maps"
                            android:textColor="@color/neon_blue"
                            android:textSize="12sp"
                            app:backgroundTint="@color/black_bg"
                            app:cornerRadius="12dp"
                            app:icon="@android:drawable/ic_menu_send"
                            app:iconSize="14dp"
                            app:iconTint="@color/neon_blue"
                            app:strokeColor="@color/neon_blue"
                            app:strokeWidth="1dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Theft / Anti-Theft Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:id="@+id/layout_theft_warning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒 Anti Pencurian Alat"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_theft_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="✓ Perangkat berada di lokasi aman"
                        android:textColor="@color/status_green"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_theft_detail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Perangkat berpindah dari lokasi awal. Kemungkinan dicuri."
                        android:textColor="@color/neon_red"
                        android:textSize="12sp"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Home Location Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏠 Lokasi Aman (Home)"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Status Home" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_home_set"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="✗ Belum diset"
                            android:textColor="@color/neon_yellow" android:textStyle="bold" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="10dp" />

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Home Latitude" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_home_lat"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="-"
                            android:textColor="@color/text_primary" android:textStyle="bold" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="10dp" />

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Home Longitude" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_home_lng"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="-"
                            android:textColor="@color/text_primary" android:textStyle="bold" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/glass_white" android:layout_marginVertical="10dp" />

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Jarak dari Home" android:textColor="@color/text_secondary" />
                        <TextView android:id="@+id/tv_distance"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="- m"
                            android:textColor="@color/neon_blue" android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Home Control Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_set_home"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="Set Lokasi Aman"
                            android:textColor="@color/status_green"
                            android:textSize="12sp"
                            app:backgroundTint="@color/card_bg"
                            app:cornerRadius="12dp"
                            app:icon="@android:drawable/ic_menu_myplaces"
                            app:iconSize="14dp"
                            app:iconTint="@color/status_green"
                            app:strokeColor="@color/status_green"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_reset_home"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="Reset Lokasi"
                            android:textColor="@color/neon_red"
                            android:textSize="12sp"
                            app:backgroundTint="@color/card_bg"
                            app:cornerRadius="12dp"
                            app:icon="@android:drawable/ic_menu_delete"
                            app:iconSize="14dp"
                            app:iconTint="@color/neon_red"
                            app:strokeColor="@color/neon_red"
                            app:strokeWidth="1dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Map Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🗺 Peta Lokasi Realtime"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Update: realtime"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </RelativeLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_marginTop="14dp">

                        <!-- Google Maps fragment (default) -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/card_gmaps"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp">
                            <fragment
                                android:id="@+id/map"
                                android:name="com.google.android.gms.maps.SupportMapFragment"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent" />
                        </androidx.cardview.widget.CardView>

                        <!-- WebView fallback (OpenStreetMap, tampil jika Maps API Key belum ada) -->
                        <WebView
                            android:id="@+id/webview_map_fallback"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_map_overlay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="10dp"
                            android:backgroundTint="#80000000"
                            android:text="Buka di Maps ↗"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            app:cornerRadius="8dp" />

                    </FrameLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Floating Bottom Navigation -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <LinearLayout android:id="@+id/nav_home"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_today" app:tint="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Dashboard" android:textColor="@color/text_secondary" android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_voltage"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_sort_by_size" app:tint="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Monitoring" android:textColor="@color/text_secondary" android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_gps"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_dialog_map" app:tint="@color/neon_blue" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Lokasi" android:textColor="@color/neon_blue" android:textSize="10sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btn_notifications"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_popup_reminder" app:tint="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Notifikasi" android:textColor="@color/text_secondary" android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_settings"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                android:background="?attr/selectableItemBackgroundBorderless">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_preferences" app:tint="@color/text_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Sistem" android:textColor="@color/text_secondary" android:textSize="10sp" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>